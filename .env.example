# PlantMD Pro — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
APP_VERSION=2.0.0

# IMPORTANT: Generate a strong secret key for production:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_SECRETS_MANAGER

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8501"]

# ── ML Model ─────────────────────────────────────────────────────────────────
MODEL_PATH=models/plantmd_efficientnet.h5
LABELS_PATH=models/labels.json
MODEL_VERSION=2.0.0
IMG_SIZE=224
CONFIDENCE_THRESHOLD=0.5

# ── Storage ───────────────────────────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=10
UPLOAD_DIR=uploads
USE_S3=false
# S3_BUCKET=your-s3-bucket-name
# AWS_REGION=us-east-1

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./plantmd.db
# For production: postgresql://user:password@localhost:5432/plantmd

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_EXPIRE_MINUTES=1440

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=false

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=30

# ── Frontend ──────────────────────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
